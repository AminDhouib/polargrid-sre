{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate by Location",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(inference_requests_total[1m])",
          "legendFormat": "{{location}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "P50 Latency by Location",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(inference_request_duration_seconds_bucket[1m]))",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "P99 Latency by Location",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(inference_request_duration_seconds_bucket[1m]))",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Error Rate by Location",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(inference_requests_total{status=\"error\"}[1m]) / rate(inference_requests_total[1m])",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      }
    },
    {
      "title": "GPU Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "gpu_utilization_percent",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Temperature",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "gpu_temperature_celsius",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "service_healthy",
          "legendFormat": "{{location}} v{{version}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "HEALTHY", "color": "green" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "title": "GPU Memory Usage",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "gpu_memory_used_gb",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "max": 24,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 18 },
              { "color": "red", "value": 22 }
            ]
          }
        }
      }
    },
    {
      "title": "Active Requests & Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "inference_active_requests",
          "legendFormat": "{{location}} active",
          "refId": "A"
        },
        {
          "expr": "inference_queue_depth",
          "legendFormat": "{{location}} queue",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Prometheus Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "legendFormat": "{{alertname}} — {{location}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "No alerts firing"
        }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["polargrid", "inference", "sre"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "title": "PolarGrid Inference — Multi-Location Overview",
  "uid": "polargrid-overview"
}
